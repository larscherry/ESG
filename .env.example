# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# Database — Render auto-sets DATABASE_URL for PostgreSQL; leave blank for local SQLite
# DATABASE_URL=postgres://user:pass@host:5432/breatheesg

# Node.js (for build step)
NODE_VERSION=22.14.0

# Gunicorn
PORT=8000
WEB_CONCURRENCY=4
